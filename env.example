# Environment Variables for Namma Pothole Production Deployment
# Copy this file to .env and fill in your actual values

# MongoDB Atlas Configuration
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/namma_pothole?retryWrites=true&w=majority

# Twilio WhatsApp Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# AWS S3 Configuration for Image Storage
AWS_ACCESS_KEY=your_aws_access_key_here
AWS_SECRET_KEY=your_aws_secret_key_here
AWS_S3_BUCKET=namma-pothole-images
AWS_S3_BUCKET_REGION=ap-south-1

# Google Maps API Key for Frontend
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional: Ngrok token for development tunneling
NGROK_AUTHTOKEN=your_ngrok_token_here

# Frontend URL for CORS
FRONTEND_URL=https://nammapothole.com

# Location instruction image URL (optional)
LOCATION_INSTRUCTION_IMAGE_URL=https://your-s3-bucket.s3.amazonaws.com/assets/location-sharing-instructions.jpg

# Dialog360 Configuration (for WhatsApp integration)
DIALOG360_API_KEY=your_dialog360_api_key_here
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_here
